    { "id": "recog_grudge_1", "slotType": "recognition", "tags": { "tone": "grudge" }, "text": "お前を認めた途端、その眼窩に昏い火が灯った。" },
    { "id": "recog_grudge_2", "slotType": "recognition", "tags": { "tone": "grudge" }, "text": "それはお前の名を正確に呼び、ゆっくりとこちらを向いた。" },

