  "crowd": {
    "spawnCount": 22,
    "kinds": {
      "commoner": { "glyph": "c", "color": "#9aa4b0", "label": "一般人（町民）",
        "lines": ["今日は冒険者が多いね。地下はおっかないよ。", "パン屋がまた値を上げた。物価は迷宮次第さ。"] },
      "merchant": { "glyph": "$", "color": "#d9b34a", "label": "商人",
        "lines": ["掘り出し物の異物だ、見ていかないか？……鑑定はしてないがね。", "各国の使いがまた来てる。きな臭いねえ。"] },
      "noble":    { "glyph": "n", "color": "#c08fd8", "label": "貴族（お忍び）",
        "lines": ["平民が。……まあいい、迷宮の英雄なら話は別だ。", "この街の富はすべて、足下の闇から湧くのだ。"] },
      "rogue":    { "glyph": "t", "color": "#d96459", "label": "悪人（ならず者）",
        "lines": ["……懐、温かそうだな。", "昨夜もまた一人帰らなかったらしいぜ。せいぜい気をつけな。"] },
      "delver":   { "glyph": "f", "color": "#6fb3c8", "label": "冒険者（ギルド所属）",
        "lines": ["次はどこまで潜る？　無理はするな、戻れなくなる。", "お前の先代の話、ギルドで聞いたよ。大した人だった。"] }
    },
