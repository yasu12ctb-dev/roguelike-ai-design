  "keepers": {
    "smith":    { "sign": "武", "color": "#e08a3c", "place": "武具屋", "name": "鍛冶ヴァロ", "title": "武具屋・二つ名「炉の番人」", "actorId": "fix_smith",
      "line": "……生きて戻ったか。なら、その得物も見てやろう。刃こぼれは命取りだぞ。",
      "acts": ["装備を売買／修理する", "異物を鑑定する", "先代の刻印武器について訊く"] },
    "store":    { "sign": "道", "color": "#6fcf97", "place": "道具屋ハル", "name": "道具屋ハル", "title": "よろず仕入れ", "actorId": "fix_store",
      "line": "灯火に縄、解毒に携行食——下で死なないための物は、ここで揃う。何が要る？",
      "acts": ["消耗品を買う", "異物・拾い物を売る", "携行品を整える"] },
    "guild":    { "sign": "組", "color": "#7fa4d8", "place": "回収業ギルド", "name": "ギルド長", "title": "ギルドの長・英雄譜の管理者", "actorId": "fix_guild",
      "line": "その血筋、覚えがある。先代の働きに免じて、いい依頼を回そう。",
      "acts": ["依頼を受ける（回収業）", "等級・英雄譜を見る", "系譜の恩寵を確かめる"] },
    "tavern":   { "sign": "酒", "color": "#e0a85a", "place": "酒場〈最後の一杯〉", "name": "女将マレン", "title": "酒場の主", "actorId": "fix_tavern",
      "line": "よく顔を見せたね。……深蝕が濃いよ。無理をしすぎだ。まず一杯おいき。",
      "acts": ["噂を聞く", "旧き名・化石のことを尋ねる", "休む（一杯やる）"] },
    "archive":  { "sign": "記", "color": "#8fd8c8", "place": "書記の館", "name": "老書記イェン", "title": "年代記の番人・長命の証人", "actorId": "fix_yen",
      "line": "わたしはみな覚えている。誰も弔わぬ者の名さえ。君の物語も、ここに。",
      "acts": ["年代記を読む", "旧キャラを伝説として承認する", "系譜をたどる"] },
    "cult":     { "sign": "教", "color": "#b07fd8", "place": "〈深淵を讃える者たち〉", "name": "仮面の教主", "title": "謎の教団", "actorId": "fix_cult",
      "line": "ようこそ、堕ちゆく者。深淵はすべてを赦し、すべてを変える。お前の深蝕は呪いではなく、祝福だ。",
      "acts": ["深淵の福音を聞く", "深蝕を捧げる（危険な恩恵）", "儀式について尋ねる"] },
    "oddments": { "sign": "異", "color": "#d87fb0", "place": "奇物堂", "name": "変わり者のクオ", "title": "異物・奇妙な武具を商う", "actorId": "fix_oddments",
      "line": "普通の武器？　よそで買いな。ここにあるのは……いわく付きばかりさ。何が起きても保証はしない。",
      "acts": ["曰く付きの武具を見る（副作用つき）", "奇妙な異物を買う", "品の曰くを聞く"] },
    "shrine":   { "sign": "弔", "color": "#9fe0d4", "place": "鎮魂の堂", "name": "弔いの巫女", "title": "鎮魂をつかさどる", "actorId": "fix_shrine",
      "line": "還らなかった者へ、祈りを。あなたが連れ帰れなかった魂も、ここで送ることができる。",
      "acts": ["化石を鎮魂する（末路を閉じる）", "先人を悼む", "深蝕を清める祈り"] },
    "healer":   { "sign": "薬", "color": "#79c98a", "place": "薬師の家", "name": "老薬師トウ", "title": "深蝕と傷を診る", "actorId": "fix_healer",
      "line": "また深蝕が進んでいるね。完全には抜けんよ——だが、進みを少し遅らせることはできる。",
      "acts": ["傷を癒す", "深蝕の進行を診てもらう", "薬を買う"] },
    "house":    { "sign": "戸", "color": "#6a6048", "place": "民家", "name": "住人", "title": "町の住人", "actorId": null,
      "line": "おや、潜る人かい。足下に気をつけて、古い床なんだ。",
      "acts": [] },
    "home":     { "sign": "宅", "color": "#c0a35e", "place": "わが家", "name": "わが家", "title": "代々の住処", "actorId": null,
      "line": "見慣れた我が家。隅の物入れは、先代から代々この家に遺されてきたものだ。",
      "acts": ["保管庫に預ける", "保管庫から引き出す", "物入れを検める"] }
  },
